> 
> # Export usable data file.
> write.table(relatedness.data, "relatedness-extract.tsv",
+     row.names = FALSE, sep = "\t")
> system(paste('dx upload relatedness-extract.tsv --path',
+     '"data-clean/relatedness-extract.tsv"'))
