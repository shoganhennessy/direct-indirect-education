> #!/usr/bin/R
> ## Senan Hogan-Hennessy, 28 Feb 2025
> ## Extract the UKB relatedness file, on UKB platform.
> 
> # Get the relatedness file.
> system('dx download -f "Bulk/Genotype Results/Genotype calls/ukb_rel.dat"')
> # Show what we are dealing with.
> readLines("ukb_rel.dat", n = 10)
 [1] "ID1 ID2 HetHet IBS0 Kinship"         "2530276 2616679 0.07 0.0056 0.2213" 
 [3] "2530276 3660169 0.083 0.0041 0.2787" "2640412 1368042 0.066 0 0.2492"     
 [5] "5645351 4364691 0.044 0.0145 0.0541" "4593836 1821383 0.048 0.0136 0.0709"
 [7] "4593836 5920366 0.076 0.0051 0.244"  "1986269 3238888 0.046 0.0147 0.0612"
 [9] "1986269 5126244 0.047 0.0128 0.076"  "3469376 6016885 0.045 0.0148 0.0571"
> 
> # Load the relatedness file.
> relatedness.data <- read.table("ukb_rel.dat", header = TRUE)
> 
> # Show format of the file.
> print(relatedness.data[1:10, ])
       ID1     ID2 HetHet   IBS0 Kinship
1  2530276 2616679  0.070 0.0056  0.2213
